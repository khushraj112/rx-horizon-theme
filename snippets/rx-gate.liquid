{%- comment -%}
  Rx Prescription Gate — message shown in place of the Add to Cart / Buy buttons.
  ------------------------------------------------------------------------------
  Rendered by blocks/buy-buttons.liquid ONLY when:
    - product is tagged `requires-rx`, AND
    - the customer is NOT tagged `rx-verified`.

  Because the buttons are not rendered at all (server-side), this cannot be
  bypassed by editing CSS in the browser. Verified customers get the normal
  buttons; everyone else sees the tag-based message + CTA below.

  Tags written by Shopify Flow: rx-pending | rx-verified | rx-rejected | rx-review
{%- endcomment -%}

<div class="rx-gate" style="border:1px solid var(--color-border, #e3e3e3);border-radius:12px;padding:1.25rem 1.5rem;margin:0.5rem 0;line-height:1.5;font-family:inherit;">
  {%- if customer == nil -%}
    <h3 style="margin:0 0 .5rem;font-size:1.05rem;">Prescription verification required</h3>
    <p style="margin:0 0 1rem;opacity:.8;">Please log in to verify your prescription license and purchase this product.</p>
    <a href="/account/login" style="display:inline-block;padding:.7rem 1.4rem;background:#1a1a1a;color:#fff;border-radius:8px;text-decoration:none;font-weight:600;">Log in</a>

  {%- elsif customer.tags contains 'rx-pending' -%}
    <h3 style="margin:0 0 .5rem;font-size:1.05rem;">Application received</h3>
    <p style="margin:0;opacity:.8;">Your prescription license is being verified. Purchasing will unlock automatically once it clears.</p>

  {%- elsif customer.tags contains 'rx-review' -%}
    <h3 style="margin:0 0 .5rem;font-size:1.05rem;">Under manual review</h3>
    <p style="margin:0;opacity:.8;">Our team is reviewing your details. We'll email you once it's approved — no further action needed right now.</p>

  {%- elsif customer.tags contains 'rx-rejected' -%}
    <h3 style="margin:0 0 .5rem;font-size:1.05rem;">Manual review required</h3>
    <p style="margin:0 0 1rem;opacity:.8;">We couldn't auto-verify your license. Submit your details for manual review by our team.</p>
    <a href="/pages/rx-manual-review" style="display:inline-block;padding:.7rem 1.4rem;background:#1a1a1a;color:#fff;border-radius:8px;text-decoration:none;font-weight:600;">Submit details for manual review</a>

  {%- else -%}
    <h3 style="margin:0 0 .5rem;font-size:1.05rem;">Verify your prescription license</h3>
    <p style="margin:0 0 1rem;opacity:.8;">This product requires a valid prescription license. Verify to purchase.</p>
    <a href="/pages/rx-apply" style="display:inline-block;padding:.7rem 1.4rem;background:#1a1a1a;color:#fff;border-radius:8px;text-decoration:none;font-weight:600;">Verify your license &rarr;</a>

  {%- endif -%}
</div>
