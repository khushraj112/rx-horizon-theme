{%- comment -%}
  Rx Prescription Gate — message shown in place of the Add to Cart / Buy buttons.
  ------------------------------------------------------------------------------
  Rendered by blocks/buy-buttons.liquid ONLY when:
    - product is tagged `requires-rx`, AND
    - the customer is NOT tagged `rx-verified`.

  Because the buttons are not rendered at all (server-side), this cannot be
  bypassed by editing CSS in the browser.

  SOURCE OF TRUTH (server-side, no localStorage):
    • Shopify Flow tags are authoritative:  rx-pending | rx-verified | rx-rejected | rx-review
    • Shopify Forms writes SYNCHRONOUSLY on submit, so we bridge the few-second
      window before Flow's tag lands — used only as a tiebreaker within a tag state:
        Form 1 submitted → tag `shopify-forms-1031424` OR metafield talon-approval.license_number
        Form 2 submitted → tag `shopify-forms-1031795` OR metafield custom.licensecredential_document
{%- endcomment -%}

{%- liquid
  assign rx_f1 = false
  if customer.tags contains 'shopify-forms-1031424'
    assign rx_f1 = true
  elsif customer.metafields['talon-approval']['license_number'].value != blank
    assign rx_f1 = true
  endif

  assign rx_f2 = false
  if customer.tags contains 'shopify-forms-1031795'
    assign rx_f2 = true
  elsif customer.metafields.custom.licensecredential_document.value != blank
    assign rx_f2 = true
  endif

  assign rx_state = 'verify'
  if customer == nil
    assign rx_state = 'guest'
  elsif customer.tags contains 'rx-verified'
    assign rx_state = 'verified'
  elsif customer.tags contains 'rx-review'
    assign rx_state = 'review'
  elsif customer.tags contains 'rx-pending'
    assign rx_state = 'pending'
  elsif customer.tags contains 'rx-rejected'
    if rx_f2
      assign rx_state = 'review'
    else
      assign rx_state = 'rejected'
    endif
  elsif rx_f1
    assign rx_state = 'pending'
  endif
-%}
<div class="rx-gate" data-rx-server="{{ rx_state }}" style="border:1px solid var(--color-border, #e3e3e3);border-radius:12px;padding:1.25rem 1.5rem;margin:0.5rem 0;line-height:1.5;font-family:inherit;">
  {%- case rx_state -%}
    {%- when 'guest' -%}
      <h3 style="margin:0 0 .5rem;font-size:1.05rem;">Prescription verification required</h3>
      <p style="margin:0 0 1rem;opacity:.8;">Please log in to verify your prescription license and purchase this product.</p>
      <a href="/account/login" style="display:inline-block;padding:.7rem 1.4rem;background:#1a1a1a;color:#fff;border-radius:8px;text-decoration:none;font-weight:600;">Log in</a>

    {%- when 'pending' -%}
      <h3 style="margin:0 0 .5rem;font-size:1.05rem;">Application received</h3>
      <p style="margin:0;opacity:.8;">Your prescription license is being verified. Purchasing will unlock automatically once it clears.</p>

    {%- when 'review' -%}
      <h3 style="margin:0 0 .5rem;font-size:1.05rem;">Under manual review</h3>
      <p style="margin:0;opacity:.8;">Our team is reviewing your details. We'll email you once it's approved — no further action needed right now.</p>

    {%- when 'rejected' -%}
      <h3 style="margin:0 0 .5rem;font-size:1.05rem;">Manual review required</h3>
      <p style="margin:0 0 1rem;opacity:.8;">We couldn't auto-verify your license. Submit your details for manual review by our team.</p>
      <a href="/pages/rx-manual-review?return_url={{ product.url | url_encode }}" style="display:inline-block;padding:.7rem 1.4rem;background:#1a1a1a;color:#fff;border-radius:8px;text-decoration:none;font-weight:600;">Submit details for manual review</a>

    {%- else -%}
      <h3 style="margin:0 0 .5rem;font-size:1.05rem;">Verify your prescription license</h3>
      <p style="margin:0 0 1rem;opacity:.8;">This product requires a valid prescription license. Verify to purchase.</p>
      <a href="/pages/rx-apply?return_url={{ product.url | url_encode }}" style="display:inline-block;padding:.7rem 1.4rem;background:#1a1a1a;color:#fff;border-radius:8px;text-decoration:none;font-weight:600;">Verify your license &rarr;</a>

  {%- endcase -%}
</div>

{%- comment -%}
  Server-truth auto-refresh (NO localStorage). While the customer is waiting on an
  automated decision (pending = Veriflow, review = staff), re-fetch the page and
  reload only when the REAL server-rendered state changes — e.g. pending → verified
  makes the gate disappear and the buy buttons render. This is read-only polling of
  authoritative server state, never an optimistic client guess.
{%- endcomment -%}
<script>
  (function () {
    var gate = document.querySelector('.rx-gate[data-rx-server]');
    if (!gate) return;
    var state = gate.getAttribute('data-rx-server');
    if (state !== 'pending' && state !== 'review') return;

    var tries = 12;
    (function poll() {
      if (tries-- <= 0) return;
      fetch(window.location.pathname + '?rxpoll=' + Date.now(), { credentials: 'same-origin', cache: 'no-store' })
        .then(function (r) { return r.text(); })
        .then(function (html) {
          var m = html.match(/data-rx-server="([^"]+)"/);
          // Gate gone (now verified → buy buttons) or state changed → reload to show real state.
          if (!m || m[1] !== state) {
            window.location.reload();
          } else {
            setTimeout(poll, 5000);
          }
        })
        .catch(function () { setTimeout(poll, 5000); });
    })();
  })();
</script>
