{%- if page.handle == 'rx-apply' or page.handle == 'rx-manual-review' -%}{%- assign rx_s = 'none' -%}{%- if customer == nil -%}{%- assign rx_s = 'guest' -%}{%- elsif customer.tags contains 'rx-verified' -%}{%- assign rx_s = 'verified' -%}{%- elsif customer.tags contains 'rx-review' -%}{%- assign rx_s = 'review' -%}{%- elsif customer.tags contains 'rx-pending' -%}{%- assign rx_s = 'pending' -%}{%- elsif customer.tags contains 'rx-rejected' -%}{%- assign rx_s = 'rejected' -%}{%- endif -%}{%- assign show_form = false -%}{%- if page.handle == 'rx-apply' and rx_s == 'none' -%}{%- assign show_form = true -%}{%- endif -%}{%- if page.handle == 'rx-manual-review' and rx_s == 'rejected' -%}{%- assign show_form = true -%}{%- endif -%}{%- unless show_form -%}<style>[id$='__forms_inline_WBPENk']{display:none!important;}</style><div class='rx-gate' style='border:1px solid #e3e3e3;border-radius:12px;padding:1.25rem 1.5rem;margin:1rem auto;max-width:640px;line-height:1.6;'>{%- if rx_s == 'guest' -%}<h3 style='margin:0 0 .5rem;'>Please log in</h3><p style='margin:0;'>Log in to your account to continue with prescription verification.</p><a href='/account/login' style='display:inline-block;margin-top:.75rem;padding:.6rem 1.2rem;background:#1a1a1a;color:#fff;border-radius:8px;text-decoration:none;font-weight:600;'>Log in</a>{%- elsif rx_s == 'pending' -%}<h3 style='margin:0 0 .5rem;'>Application received</h3><p style='margin:0;'>Your license is being verified automatically. No need to submit again - this page updates on its own once it clears.</p>{%- elsif rx_s == 'review' -%}<h3 style='margin:0 0 .5rem;'>Under manual review</h3><p style='margin:0;'>Our team is reviewing your details. We will email you as soon as it is approved.</p>{%- elsif rx_s == 'verified' -%}<h3 style='margin:0 0 .5rem;'>You are verified</h3><p style='margin:0;'>Your prescription access is active. You can purchase Rx products now.</p>{%- elsif rx_s == 'rejected' -%}<h3 style='margin:0 0 .5rem;'>Manual review required</h3><p style='margin:0;'>We could not auto-verify your license. Please submit it for manual review.</p><a href='/pages/rx-manual-review' style='display:inline-block;margin-top:.75rem;padding:.6rem 1.2rem;background:#1a1a1a;color:#fff;border-radius:8px;text-decoration:none;font-weight:600;'>Submit for manual review</a>{%- else -%}<h3 style='margin:0 0 .5rem;'>No application found</h3><p style='margin:0;'>Start by submitting your license for verification.</p><a href='/pages/rx-apply' style='display:inline-block;margin-top:.75rem;padding:.6rem 1.2rem;background:#1a1a1a;color:#fff;border-radius:8px;text-decoration:none;font-weight:600;'>Apply now</a>{%- endif -%}</div>{%- endunless -%}{%- endif -%}